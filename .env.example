# App
APP_ENV=development
APP_PORT=8000
APP_VERSION=1.0.0

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Redis
REDIS_URL=redis://localhost:6379/0

# File Storage
TEMP_DOWNLOAD_DIR=/tmp/downloads
FILE_EXPIRY_MINUTES=5

# Rate Limiting
RATE_LIMIT_INFO=10
RATE_LIMIT_INFO_WINDOW_SECONDS=60
RATE_LIMIT_DOWNLOAD=3
RATE_LIMIT_DOWNLOAD_WINDOW_SECONDS=600

# Cache
INFO_CACHE_TTL_SECONDS=600

# yt-dlp
YTDLP_COOKIEFILE=
YTDLP_PROXY=
